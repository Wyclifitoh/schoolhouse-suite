# CHUO Workers Environment Variables

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/chuo

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# M-Pesa Configuration (Daraja API)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENVIRONMENT=sandbox  # 'sandbox' or 'production'

# Africa's Talking (SMS Provider)
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox  # 'sandbox' for testing

# AWS S3 (Report Storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Worker Concurrency
CONCURRENCY_PAYMENTS=5
CONCURRENCY_NOTIFICATIONS=10
CONCURRENCY_REPORTS=2

# Environment
NODE_ENV=development
